---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const businessName = 'Affordable Fence & Railing, LLC';
const currentPath = Astro.url.pathname;

const topLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
];

const fencingLinks = [
  { href: '/vinyl-fences', label: 'Vinyl Fences' },
  { href: '/aluminum-fences', label: 'Aluminum Fences' },
  { href: '/chain-link', label: 'Chain Link' },
  { href: '/railing', label: 'Railing' },
];

const bottomLinks = [
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];

const allLinks = [...topLinks, ...fencingLinks, ...bottomLinks];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

const fencingActive = fencingLinks.some(l => isActive(l.href));
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <script async src="https://api.keithkelly.dev/d/s"></script>
  <script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init({endpoint:"https://api.keithkelly.dev/d/e"})</script>
</head>
<body>
  <header class="sticky top-0 z-50 bg-background/95 backdrop-blur-sm border-b border-border">
    <div class="max-w-[1200px] mx-auto flex items-center justify-between px-6 md:px-12 py-4">
      <a href="/" class="flex items-center gap-2">
        <svg class="h-6 w-6 md:h-7 md:w-7 text-primary flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 3 2 5v15c0 .6.4 1 1 1h2c.6 0 1-.4 1-1V5Z"/><path d="M6 8h4"/><path d="M6 18h4"/><path d="m12 3-2 2v15c0 .6.4 1 1 1h2c.6 0 1-.4 1-1V5Z"/><path d="M14 8h4"/><path d="M14 18h4"/><path d="m20 3-2 2v15c0 .6.4 1 1 1h2c.6 0 1-.4 1-1V5Z"/>
        </svg>
        <div class="flex flex-col leading-tight min-w-0">
          <span class="font-display text-base md:text-lg font-bold text-foreground tracking-tight truncate">Affordable Fence & Railing</span>
          <span class="text-xs text-muted-foreground font-medium tracking-wide uppercase hidden md:block">Pittsburgh, PA</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {topLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-md',
              isActive(link.href)
                ? 'text-primary bg-primary/8'
                : 'text-foreground/70 hover:text-foreground hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}

        <!-- Fencing dropdown -->
        <div class="relative" id="fencing-dropdown">
          <button
            type="button"
            class:list={[
              'flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md',
              fencingActive
                ? 'text-primary bg-primary/8'
                : 'text-foreground/70 hover:text-foreground hover:bg-muted',
            ]}
            id="fencing-trigger"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Fencing
            <svg class="w-3.5 h-3.5 mt-0.5 transition-transform" id="fencing-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="fencing-panel" class="hidden absolute top-full left-0 pt-2 z-50">
          <div class="w-48 bg-background border border-border rounded-lg shadow-lg py-1">
            {fencingLinks.map(link => (
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-2.5 text-sm font-medium',
                  isActive(link.href)
                    ? 'text-primary bg-primary/8'
                    : 'text-foreground/70 hover:text-foreground hover:bg-muted',
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>
          </div>
        </div>

        {bottomLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-md',
              isActive(link.href)
                ? 'text-primary bg-primary/8'
                : 'text-foreground/70 hover:text-foreground hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}

        <a
          href="tel:412-766-1464"
          class="ml-3 px-5 py-2.5 bg-primary text-primary-foreground text-sm font-semibold rounded-full"
        >
          412-766-1464
        </a>
      </nav>

      <!-- Mobile toggle -->
      <div class="flex items-center gap-3 lg:hidden">
        <a href="tel:412-766-1464" class="text-primary font-semibold text-sm">Call Us</a>
        <button id="menu-toggle" class="p-2 rounded-md hover:bg-muted" aria-label="Toggle menu" aria-expanded="false">
          <svg id="hamburger-icon" class="w-6 h-6 text-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 text-foreground hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu (flat list) -->
    <nav id="mobile-menu" class="hidden lg:hidden border-t border-border bg-background">
      <div class="px-6 py-4 flex flex-col gap-1">
        {topLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-3 text-sm font-medium rounded-md',
              isActive(link.href)
                ? 'text-primary bg-primary/8'
                : 'text-foreground/70 hover:text-foreground hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}
        <p class="px-4 pt-3 pb-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">Fencing</p>
        {fencingLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-3 pl-6 text-sm font-medium rounded-md',
              isActive(link.href)
                ? 'text-primary bg-primary/8'
                : 'text-foreground/70 hover:text-foreground hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}
        {bottomLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-3 text-sm font-medium rounded-md',
              isActive(link.href)
                ? 'text-primary bg-primary/8'
                : 'text-foreground/70 hover:text-foreground hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="tel:412-766-1464"
          class="mt-2 px-5 py-3 bg-primary text-primary-foreground text-sm font-semibold rounded-full text-center"
        >
          Call 412-766-1464
        </a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="bg-foreground text-background/80">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <p class="font-display text-lg font-bold text-background mb-4">Affordable Fence & Railing</p>
          <p class="text-sm leading-relaxed mb-4">Locally owned fence and railing company serving Pittsburgh and surrounding counties for over 30 years. Fully licensed and insured.</p>
          <div class="flex gap-4 mt-4">
            <a href="https://facebook.com/Affordable-Fence-Railing-LLC-600448523453587" aria-label="Facebook" class="text-background/60 hover:text-background">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/afc_pgh_pa/" aria-label="Instagram" class="text-background/60 hover:text-background">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>

        <div>
          <p class="font-semibold text-background mb-4 text-sm uppercase tracking-wider">Quick Links</p>
          <div class="flex flex-col gap-2">
            {allLinks.map(link => (
              <a href={link.href} class="text-sm text-background/70 hover:text-background">{link.label}</a>
            ))}
          </div>
        </div>

        <div>
          <p class="font-semibold text-background mb-4 text-sm uppercase tracking-wider">Contact Info</p>
          <div class="flex flex-col gap-3 text-sm">
            <a href="tel:412-766-1464" class="text-background/70 hover:text-background">Phone: 412-766-1464</a>
            <p class="text-background/70">Fax: 412-230-8654</p>
            <a href="mailto:carol@affordable-fences.com" class="text-background/70 hover:text-background">carol@affordable-fences.com</a>
            <p class="text-background/70">309 Camp Horne Road<br />Pittsburgh, PA 15202</p>
            <p class="text-background/70">Mon-Fri: 9:00 AM - 4:30 PM<br />Sat-Sun: Closed</p>
          </div>
        </div>
      </div>

      <div class="border-t border-background/15 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-sm text-background/50">&copy; {new Date().getFullYear()} Affordable Fence & Railing, LLC. All rights reserved.</p>
        <p class="text-sm text-background/50">Fully Licensed & Insured</p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    toggle?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      hamburger?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
      toggle?.setAttribute('aria-expanded', String(!isOpen));
    });

    // Desktop fencing dropdown
    const dropdown = document.getElementById('fencing-dropdown');
    const trigger = document.getElementById('fencing-trigger');
    const panel = document.getElementById('fencing-panel');
    const chevron = document.getElementById('fencing-chevron');

    function openDropdown() {
      panel?.classList.remove('hidden');
      chevron?.style.setProperty('transform', 'rotate(180deg)');
      trigger?.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown() {
      panel?.classList.add('hidden');
      chevron?.style.setProperty('transform', 'rotate(0deg)');
      trigger?.setAttribute('aria-expanded', 'false');
    }

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !panel?.classList.contains('hidden');
      if (isOpen) {
        closeDropdown();
      } else {
        openDropdown();
      }
    });

    // Open on hover (desktop) with delay on close
    let closeTimer: ReturnType<typeof setTimeout> | null = null;

    dropdown?.addEventListener('mouseenter', () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      openDropdown();
    });

    dropdown?.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(closeDropdown, 150);
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!dropdown?.contains(e.target as Node)) {
        closeDropdown();
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeDropdown();
      }
    });
  </script>
</body>
</html>
