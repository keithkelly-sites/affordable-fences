---
import Layout from '../layouts/Layout.astro';

const benefits = [
  { title: 'Safety & Security', description: 'Provides a secure barrier for porches, decks, staircases, and balconies.' },
  { title: 'Custom Fabrication', description: 'We fabricate railings to fit your exact specifications and dimensions.' },
  { title: 'Multiple Materials', description: 'Choose between aluminum and vinyl railing systems to suit your needs.' },
  { title: 'Code Compliant', description: 'All installations meet local building code requirements and ADA standards.' },
  { title: 'Adds Home Value', description: 'An attractive railing system adds curb appeal and value to your property.' },
  { title: 'Low Maintenance', description: 'Both aluminum and vinyl railing require minimal upkeep over time.' },
];

const applications = [
  'Front Porches',
  'Decks',
  'Exterior Staircases',
  'Handicap Ramps',
  'Balconies',
];
---

<Layout
  title="Railing Installation - Affordable Fence & Railing, LLC"
  description="Aluminum and vinyl railing installation in Pittsburgh, PA. Custom fabrication for porches, decks, staircases, handicap ramps, and balconies. Free estimates."
>
  <!-- Hero -->
  <section class="bg-muted py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="max-w-2xl">
        <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-3">Our Products</p>
        <h1>Railing Installations in Pittsburgh, PA</h1>
        <p class="text-foreground/70 text-lg mt-6 leading-relaxed">
          Aluminum and vinyl railing systems fabricated and installed for exterior residential projects. Customizable spacing, finishes, and colors.
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="mb-6">Custom Railing for Your Home</h2>
          <p class="text-foreground/70 leading-relaxed mb-4">
            At Affordable Fence & Railing, we fabricate and install several different types of railing systems for exterior residential projects. We use high-quality products for aluminum railing and vinyl railing systems.
          </p>
          <p class="text-foreground/70 leading-relaxed mb-4">
            With a correctly fabricated and installed railing system, you can add an attractive and functional structure to your home, providing security while adding to your home's value.
          </p>
          <p class="text-foreground/70 leading-relaxed mb-4">
            We can customize your railings to suit your preferences while staying within your budget. Typical customizations include spacing, finishes, and colors.
          </p>

          <div class="mt-8">
            <p class="text-sm font-semibold mb-3">Where we install:</p>
            <div class="flex flex-wrap gap-3">
              {applications.map(app => (
                <span class="px-4 py-2 bg-primary/8 text-primary text-sm font-medium rounded-full">{app}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <img
            src="/images/img_2033-640w-1920w.webp"
            alt="Residential Aluminum Railing"
            class="rounded-lg w-full"
            loading="lazy"
          />
          <img
            src="/images/img_2117-640w-1920w.webp"
            alt="Black Metal Railing For Stairs"
            class="rounded-lg w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-muted py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="max-w-xl mb-14">
        <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-2">Benefits</p>
        <h2>Why Choose Our Railing</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map((benefit, i) => (
          <div class="flex gap-4">
            <span class="text-3xl font-display font-bold text-primary/20 leading-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="text-base mb-2">{benefit.title}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">{benefit.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Row -->
  <section class="py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <img src="/images/517-640w-1920w.webp" alt="Porch with White Fence" class="rounded-lg w-full h-64 object-cover" loading="lazy" />
        <img src="/images/img_1176-640w-1920w.webp" alt="Railing Installation" class="rounded-lg w-full h-64 object-cover" loading="lazy" />
        <img src="/images/img_1177-640w-1920w.webp" alt="Staircase Railing" class="rounded-lg w-full h-64 object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary/5 py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 text-center">
      <h2 class="mb-4">Need Railing for Your Home?</h2>
      <p class="text-muted-foreground max-w-xl mx-auto mb-8">
        If you are looking for durable and functional railing, call our team today in Pittsburgh, PA, for a free estimate.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-primary-foreground font-semibold rounded-full text-sm">
          Request a Free Estimate
        </a>
        <a href="tel:412-766-1464" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-primary/30 text-primary font-semibold rounded-full text-sm">
          Call 412-766-1464
        </a>
      </div>
    </div>
  </section>
</Layout>
