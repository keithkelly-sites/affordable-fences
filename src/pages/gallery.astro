---

<Layout
  title="Gallery - Affordable Fence & Railing, LLC"
  description="Browse completed fence and railing projects by Affordable Fence & Railing in Pittsburgh, PA. Vinyl, aluminum, chain link fences and railing installations."
>
  <!-- Header -->
  <section class="page-header section">
    <div class="wrap">
      <span class="label">Our Work</span>
      <h1>Completed Projects</h1>
      <p>Fence and railing installations across Pittsburgh and surrounding areas. Every project completed to code, built to last.</p>
    </div>
  </section>

  <!-- Masonry gallery -->
  <section class="gallery">
    <div class="wrap">
      <div class="masonry">
        {images.map(img => (
          <div class:list={['masonry-item', { tall: img.tall }]}>
            <img src={`/images/${img.file}`} alt={img.alt} loading="lazy" />
            <div class="caption">
              <p>{img.alt}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta section">
    <div class="wrap cta-inner">
      <h2>Like What You See?</h2>
      <p>Call us today for a free estimate and let us build the fence or railing your property needs.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Request a Free Estimate</a>
        <a href="tel:412-766-1464" class="btn btn-outline">Call 412-766-1464</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--charcoal);
    background-image: var(--picket-pattern);
  }

  .label {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--amber);
    margin-bottom: 0.75rem;
  }

  .page-header h1 {
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .page-header p {
    color: var(--silver);
    max-width: 45ch;
  }

  /* Masonry layout */
  .gallery {
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .masonry {
    columns: 1;
    gap: var(--space-sm);
  }

  @media (min-width: 640px) {
    .masonry { columns: 2; }
  }

  @media (min-width: 960px) {
    .masonry { columns: 3; }
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: var(--space-sm);
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    background: var(--cream-dark);
  }

  .masonry-item img {
    width: 100%;
    display: block;
    transition: transform 0.5s var(--ease-out);
  }

  .masonry-item:hover img {
    transform: scale(1.03);
  }

  .caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 1rem 0.75rem;
    background: linear-gradient(to top, oklch(0 0 0 / 0.65), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .masonry-item:hover .caption {
    opacity: 1;
  }

  .caption p {
    color: var(--white);
    font-size: 0.8125rem;
    font-weight: 500;
  }

  /* CTA */
  .cta {
    background: var(--teal);
    text-align: center;
  }

  .cta-inner { max-width: 600px; }
  .cta h2 { color: var(--white); margin-bottom: 0.75rem; }
  .cta p { color: oklch(1 0 0 / 0.75); margin-bottom: var(--space-lg); }
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
</style>
