---

<Layout
  title="Gallery - Affordable Fence & Railing, LLC"
  description="Browse completed fence and railing projects by Affordable Fence & Railing in Pittsburgh, PA. Vinyl, aluminum, chain link fences and railing installations."
>
  <!-- Hero -->
  <section class="bg-muted py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="max-w-2xl">
        <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-3">Our Work</p>
        <h1>Completed Projects</h1>
        <p class="text-foreground/70 text-lg mt-6 leading-relaxed">
          Browse through some of our completed fence and railing installations across Pittsburgh and surrounding areas.
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {galleryImages.map(img => (
          <div class="break-inside-avoid rounded-lg overflow-hidden border border-border">
            <img
              src={`/images/${img.file}`}
              alt={img.alt}
              class="w-full h-auto"
              loading="lazy"
            />
            <div class="px-4 py-3 bg-background">
              <p class="text-xs text-muted-foreground">{img.alt}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-foreground py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 text-center">
      <h2 class="text-background mb-4">Like What You See?</h2>
      <p class="text-background/60 max-w-xl mx-auto mb-8">
        Call us today for a free estimate and let us build the fence or railing your property needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-primary-foreground font-semibold rounded-full text-sm">
          Request a Free Estimate
        </a>
        <a href="tel:412-766-1464" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-background/30 text-background font-semibold rounded-full text-sm">
          Call 412-766-1464
        </a>
      </div>
    </div>
  </section>
</Layout>
