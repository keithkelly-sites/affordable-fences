---
/*
  DESIGN CONCEPT: "The Line That Defines"

  Inspired by architectural portfolio sites that treat typography as structure.
  The company name at monumental scale (Big Shoulders Display at 15vw+) in warm
  amber against deep charcoal, with subtle repeating vertical lines evoking fence
  pickets. This is the signature moment — the type IS the fence.

  Color palette drawn from their logo's dark teal, paired with warm amber CTAs
  against alternating charcoal and cream. The dark/light rhythm mirrors fence
  posts along a property line.

  Reference sites studied:
  - Awwwards architecture portfolios using oversized condensed type
  - Industrial/construction sites with scroll-triggered reveals and bold geometry
  - The repeating vertical rhythm of fence pickets as a CSS background motif
*/

import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    text: "Affordable Fencing was professional and very easy to work with. They did a good job during installation and the fence looks great!",
    author: "Chris P.",
  },
  {
    text: "Affordable Fence and Railing was a perfect fit for us. We are very pleased with how our fence looks, and the craftsman that installed it was pleasant and attentive to our concerns. Highly Recommend this company.",
    author: "John A.",
  },
  {
    text: "Affordable Fence was great all the way around and easy to work with. They came out in a timely manner to give an estimate and the same with the installation. Curt and Nathan were very helpful and answered all of our questions. The fence looks great and we are happy. Thank you!",
    author: "Beth C.",
  },
];

const services = [
  {
    title: 'Vinyl Fences',
    href: '/vinyl-fences',
    image: '/images/175545195-1920w.jpg',
    alt: 'White vinyl privacy fence on green lawn',
    stat: '5x',
    statLabel: 'stronger than wood',
  },
  {
    title: 'Aluminum',
    href: '/aluminum-fences',
    image: '/images/gettyimages-1139142927-1920w.jpg',
    alt: 'Black aluminum fence in dramatic perspective',
    stat: '0',
    statLabel: 'corrosion',
  },
  {
    title: 'Chain Link',
    href: '/chain-link',
    image: '/images/gettyimages-928863520-1920w.jpg',
    alt: 'Chain link fence at sunset',
    stat: '$0',
    statLabel: 'maintenance cost',
  },
  {
    title: 'Railing',
    href: '/railing',
    image: '/images/img_2117-640w-1920w.webp',
    alt: 'Black metal railing on stone stairs',
    stat: 'ADA',
    statLabel: 'code compliant',
  },
];
---

<Layout
  title="Affordable Fence & Railing, LLC - Fence Company in Pittsburgh, PA"
  description="Locally owned fence and railing company serving Pittsburgh and surrounding counties for over 30 years. Vinyl, aluminum, chain link fences and railing installation. Free estimates."
  ogImage="/images/175545195-1920w.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Affordable Fence & Railing, LLC",
    "url": "https://affordable-fences.keithkelly.dev",
    "telephone": "412-766-1464",
    "email": "carol@affordable-fences.com",
    "image": "https://affordable-fences.keithkelly.dev/images/175545195-1920w.jpg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "309 Camp Horne Road",
      "addressLocality": "Pittsburgh",
      "addressRegion": "PA",
      "postalCode": "15202",
      "addressCountry": "US"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "16:30"
    },
    "areaServed": [
      "Pittsburgh", "Sewickley", "Cranberry Township", "Moon Township",
      "Wexford", "Canonsburg", "Allegheny County", "Butler County",
      "Beaver County", "Westmoreland County", "Washington County"
    ],
    "paymentAccepted": "Visa, MasterCard, American Express, Discover, Cash, Check",
    "priceRange": "$$"
  })} />
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content wrap">
      <p class="hero-sub">Pittsburgh, PA &middot; Since 1993</p>
      <h1 class="hero-title">
        <span class="hero-word-main">Affordable</span>
        <span class="hero-word-sub">Fence & Railing</span>
      </h1>
      <p class="hero-tagline">Locally owned. Fully licensed. Over 30 years of fence and railing installations across five counties.</p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Free Estimate</a>
        <a href="tel:412-766-1464" class="btn btn-outline">412-766-1464</a>
      </div>
    </div>
    <div class="hero-photo">
      <img src="/images/175545195-1920w.jpg" alt="White vinyl privacy fence installed by Affordable Fence & Railing" loading="eager" fetchpriority="high" />
    </div>
  </section>

  <!-- ============ MARQUEE TRUST STRIP ============ -->
  <div class="marquee-strip" aria-hidden="true">
    <div class="marquee-track">
      {[0,1,2,3].map(() => (
        <div class="marquee-set">
          <span>30+ Years in Business</span>
          <span class="marquee-dot">&bull;</span>
          <span>Fully Licensed & Insured</span>
          <span class="marquee-dot">&bull;</span>
          <span>Free Estimates</span>
          <span class="marquee-dot">&bull;</span>
          <span>Financing Available</span>
          <span class="marquee-dot">&bull;</span>
          <span>5 Counties Served</span>
          <span class="marquee-dot">&bull;</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ============ SERVICES ============ -->
  <section class="services section">
    <div class="wrap">
      <div class="services-header reveal">
        <h2>What We Build</h2>
        <p>Every material. Every property. One standard of quality.</p>
      </div>
      <div class="services-grid">
        {services.map((s, i) => (
          <a href={s.href} class:list={['service-card', 'reveal', `delay-${i}`]}>
            <img src={s.image} alt={s.alt} loading="lazy" />
            <div class="service-overlay">
              <span class="service-stat">{s.stat}</span>
              <span class="service-stat-label">{s.statLabel}</span>
            </div>
            <div class="service-info">
              <h3>{s.title}</h3>
              <span class="service-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ABOUT STRIP ============ -->
  <section class="about-strip section">
    <div class="wrap about-grid">
      <div class="about-photos reveal">
        <img src="/images/img_2043-640w-1920w.webp" alt="White picket fence on green hillside" class="about-photo-1" loading="lazy" />
        <img src="/images/img_2119-640w-1920w.webp" alt="Black aluminum gate at brick house" class="about-photo-2" loading="lazy" />
      </div>
      <div class="about-text reveal">
        <h2>Built Right, Priced Fair</h2>
        <p>We provide affordable residential fence installation and fabrication using high-quality products. Every project completed safely and within local building code guidelines.</p>
        <p>Whether you need a white vinyl privacy fence, a black aluminum perimeter, or a simple chain link, we bring the same attention to detail and fair pricing.</p>
        <a href="/about" class="about-link">More about us &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="testimonials section">
    <div class="wrap">
      <div class="testimonial-header reveal">
        <h2>What Customers Say</h2>
      </div>
      <div class="testimonial-grid">
        {testimonials.map((t, i) => (
          <div class:list={['testimonial', 'reveal', `delay-${i}`]}>
            <div class="quote-mark" aria-hidden="true">&ldquo;</div>
            <blockquote>{t.text}</blockquote>
            <cite>{t.author}</cite>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SERVICE AREA ============ -->
  <section class="area section">
    <div class="wrap area-inner">
      <div class="area-text reveal">
        <h2>Serving Pittsburgh & Beyond</h2>
        <p>We cover Allegheny, Butler, Beaver, Westmoreland, and Washington counties.</p>
      </div>
      <div class="area-tags reveal">
        {['Pittsburgh', 'Sewickley', 'Cranberry Twp', 'Moon Twp', 'Wexford', 'Canonsburg'].map(area => (
          <span class="area-tag">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="final-cta section">
    <div class="wrap cta-inner">
      <h2>Ready to Start Your Fence Project?</h2>
      <p>Contact us for a free estimate. We'll come to your property, discuss your needs, and provide a competitive quote.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-primary">Request a Free Estimate</a>
        <a href="tel:412-766-1464" class="btn btn-outline">Call 412-766-1464</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ==================
     HERO — The signature moment
     ================== */
  .hero {
    position: relative;
    min-height: 100svh;
    background: var(--charcoal);
    background-image: var(--picket-pattern);
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-3xl) var(--space-xl);
  }

  @media (min-width: 768px) {
    .hero-content {
      padding-block: 0;
      max-width: 600px;
      margin-left: auto;
      padding-right: var(--space-xl);
    }
  }

  .hero-sub {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--amber);
    margin-bottom: var(--space-md);
  }

  .hero-title {
    margin-bottom: var(--space-lg);
  }

  .hero-word-main {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--amber);
  }

  .hero-word-sub {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: oklch(1 0 0 / 0.5);
    margin-top: 0.25em;
  }

  .hero-tagline {
    color: oklch(1 0 0 / 0.6);
    max-width: 38ch;
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-photo {
    position: relative;
    min-height: 300px;
    z-index: 1;
  }

  @media (max-width: 767px) {
    .hero-photo {
      margin-inline: calc(var(--gutter) * -1);
    }
  }

  .hero-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .hero-photo {
      clip-path: polygon(15% 0, 100% 0, 100% 100%, 0 100%);
    }
  }

  /* ==================
     MARQUEE TRUST STRIP
     ================== */
  .marquee-strip {
    background: var(--teal);
    padding: 0.875rem 0;
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .marquee-set {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--white);
    white-space: nowrap;
  }

  .marquee-set span {
    flex-shrink: 0;
    padding-inline: 1.5rem;
  }

  .marquee-dot {
    color: oklch(1 0 0 / 0.3);
  }

  /* ==================
     SERVICES
     ================== */
  .services-header {
    margin-bottom: var(--space-xl);
  }

  .services-header p {
    color: var(--steel);
    margin-top: 0.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 420px;
    }
  }

  .service-card {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 3 / 4;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    cursor: pointer;
  }

  @media (min-width: 960px) {
    .service-card { aspect-ratio: unset; }
  }

  .service-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .service-card:hover img {
    transform: scale(1.06);
  }

  .service-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: oklch(0.14 0.005 260 / 0.55);
    transition: background 0.3s;
  }

  .service-card:hover .service-overlay {
    background: oklch(0.14 0.005 260 / 0.7);
  }

  .service-stat {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--amber);
    line-height: 1;
  }

  .service-stat-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: oklch(1 0 0 / 0.5);
    margin-top: 0.25rem;
  }

  .service-info {
    position: relative;
    z-index: 1;
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--charcoal);
  }

  .service-info h3 {
    color: var(--white);
    font-size: 0.9375rem;
    margin: 0;
  }

  .service-arrow {
    color: var(--amber);
    font-size: 1.25rem;
    transition: transform 0.3s;
  }

  .service-card:hover .service-arrow {
    transform: translateX(4px);
  }

  /* Animation delays */
  .delay-0 { transition-delay: 0s; }
  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  /* ==================
     ABOUT STRIP
     ================== */
  .about-strip {
    background: var(--cream-dark);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-grid { grid-template-columns: 1fr 1fr; }
  }

  .about-photos {
    display: grid;
    grid-template-columns: 5fr 4fr;
    gap: var(--space-sm);
  }

  .about-photo-1 {
    border-radius: 4px;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3 / 4;
  }

  .about-photo-2 {
    border-radius: 4px;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3 / 4;
    margin-top: var(--space-xl);
  }

  .about-text h2 {
    margin-bottom: var(--space-md);
  }

  .about-text p {
    color: var(--steel);
  }

  .about-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--teal);
    transition: color 0.2s;

    &:hover { color: var(--teal-light); }
  }

  /* ==================
     TESTIMONIALS
     ================== */
  .testimonials {
    background: var(--charcoal);
    background-image: var(--picket-pattern);
  }

  .testimonial-header {
    margin-bottom: var(--space-xl);
  }

  .testimonial-header h2 {
    color: var(--white);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .testimonial-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .testimonial {
    padding: var(--space-lg);
    border-left: 2px solid var(--teal);
    position: relative;
  }

  .quote-mark {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 800;
    color: oklch(1 0 0 / 0.06);
    line-height: 1;
    position: absolute;
    top: 0.75rem;
    left: 1.25rem;
  }

  .testimonial blockquote {
    color: oklch(1 0 0 / 0.7);
    font-size: 0.9375rem;
    font-style: italic;
    line-height: 1.7;
    margin-bottom: var(--space-sm);
    position: relative;
  }

  .testimonial cite {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--amber);
  }

  /* ==================
     SERVICE AREA
     ================== */
  .area {
    background: var(--cream-dark);
  }

  .area-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    align-items: center;
    justify-content: space-between;
  }

  .area-text h2 {
    margin-bottom: 0.5rem;
  }

  .area-text p {
    color: var(--steel);
  }

  .area-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .area-tag {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    background: var(--white);
    border: 1px solid oklch(0 0 0 / 0.06);
    border-radius: 4px;
    color: var(--iron);
  }

  /* ==================
     FINAL CTA
     ================== */
  .final-cta {
    background: var(--teal);
    text-align: center;
  }

  .cta-inner {
    max-width: 620px;
  }

  .final-cta h2 {
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .final-cta p {
    color: oklch(1 0 0 / 0.75);
    margin-bottom: var(--space-lg);
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
</style>
