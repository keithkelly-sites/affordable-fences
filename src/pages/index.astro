---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    text: "Affordable Fencing was professional and very easy to work with. They did a good job during installation and the fence looks great!",
    author: "Chris P.",
  },
  {
    text: "Affordable Fence and Railing was a perfect fit for us. We are very pleased with how our fence looks, and the craftsman that installed it was pleasant and attentive to our concerns. Highly Recommend this company.",
    author: "John A.",
  },
  {
    text: "Affordable Fence was great all the way around and easy to work with. They came out in a timely manner to give an estimate and the same with the installation. Curt and Nathan were very helpful and answered all of our questions. The fence looks great and we are happy. Thank you!",
    author: "Beth C.",
  },
];

const services = [
  {
    title: 'Vinyl Fences',
    href: '/vinyl-fences',
    image: '/images/175545195-1920w.jpg',
    alt: 'Vinyl Fence in Pittsburgh, PA',
    description: 'Five times stronger than wood. Low maintenance, durable, and available in picket and privacy styles.',
  },
  {
    title: 'Aluminum Fences',
    href: '/aluminum-fences',
    image: '/images/gettyimages-1139142927-1920w.jpg',
    alt: 'Aluminum Fence in Pittsburgh, PA',
    description: 'Corrosion-resistant fencing for residential and commercial properties. Customizable color, height, and finish.',
  },
  {
    title: 'Chain Link',
    href: '/chain-link',
    image: '/images/gettyimages-928863520-1920w.jpg',
    alt: 'Chain Link Fence in Pittsburgh, PA',
    description: 'Maintenance-free chain link in galvanized or black vinyl-coated options. Sliding and swinging gates available.',
  },
  {
    title: 'Railing',
    href: '/railing',
    image: '/images/img_2033-640w-1920w.webp',
    alt: 'Residential Aluminum Railing in Pittsburgh, PA',
    description: 'Aluminum and vinyl railing for porches, decks, staircases, handicap ramps, and balconies.',
  },
];
---

<Layout
  title="Affordable Fence & Railing, LLC - Fence Company in Pittsburgh, PA"
  description="Locally owned fence and railing company serving Pittsburgh and surrounding counties for over 30 years. Vinyl, aluminum, chain link fences and railing installation. Free estimates."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <img src="/images/175545195-1920w.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-primary/80"></div>
    <div class="relative max-w-[1200px] mx-auto px-6 md:px-12 pt-24 pb-20 md:pt-36 md:pb-28">
      <p class="text-primary-foreground/70 text-sm font-medium uppercase tracking-widest mb-4">Over 30 Years Serving Pittsburgh, PA</p>
      <h1 class="text-primary-foreground max-w-2xl mb-6">Quality Fence Installations for Your Property</h1>
      <p class="text-primary-foreground/80 text-lg max-w-xl mb-10 leading-relaxed">
        Affordable Fence & Railing is a locally owned, full-service fence and railing company. We use high-quality products and stand behind every installation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-background text-primary font-semibold rounded-full text-sm">
          Get a Free Estimate
        </a>
        <a href="tel:412-766-1464" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-primary-foreground/30 text-primary-foreground font-semibold rounded-full text-sm">
          Call 412-766-1464
        </a>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="max-w-xl mb-14">
        <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-2">Our Services</p>
        <h2>Fence and Railing for Every Need</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {services.map(service => (
          <a href={service.href} class="group block rounded-lg overflow-hidden border-2 border-border bg-background">
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={service.image}
                alt={service.alt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6 border-t-2 border-primary/20">
              <h3 class="mb-2 group-hover:text-primary">{service.title}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">{service.description}</p>
              <span class="inline-block mt-4 text-primary text-sm font-semibold">Learn more &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-muted py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-2">Why Choose Us</p>
          <h2 class="mb-6">Trusted by Pittsburgh Homeowners Since 1993</h2>
          <p class="text-muted-foreground leading-relaxed mb-8">
            We provide affordable residential fence installation and fabrication using high-quality products. Our team completes every project safely and within local building code guidelines, so your new fence looks great without violating any regulations.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Fully Licensed & Insured</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="font-semibold text-sm">30+ Years Experience</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Free Estimates</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Financing Available</p>
              </div>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <img src="/images/img_2286-640w-1920w.webp" alt="White Fence in a Lawn" class="rounded-lg w-full h-48 md:h-64 object-cover" loading="lazy" />
          <img src="/images/img_2043-640w-1920w.webp" alt="Green Yard with White Fence" class="rounded-lg w-full h-48 md:h-64 object-cover mt-8" loading="lazy" />
          <img src="/images/img_2119-640w-1920w.webp" alt="Black Fence and Gate of a House" class="rounded-lg w-full h-48 md:h-64 object-cover" loading="lazy" />
          <img src="/images/505-640w-1920w.webp" alt="Black Painted Aluminum Fence" class="rounded-lg w-full h-48 md:h-64 object-cover mt-8" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="max-w-xl mb-14">
        <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-2">What Our Customers Say</p>
        <h2>5-Star Reviews From Real Customers</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="border-l-3 border-primary/40 pl-6 py-2">
            <div class="flex gap-1 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-foreground/80 text-sm leading-relaxed italic mb-4">"{t.text}"</p>
            <p class="text-sm font-semibold text-foreground">{t.author}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="bg-primary/5 py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 text-center">
      <p class="text-primary text-sm font-semibold uppercase tracking-wider mb-2">Our Service Area</p>
      <h2 class="mb-6">Serving Pittsburgh & Surrounding Counties</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto mb-10">
        We serve homeowners across Allegheny, Butler, Beaver, Westmoreland, and Washington counties, including Sewickley, Cranberry Township, Moon Township, Wexford, and Canonsburg.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {['Pittsburgh', 'Sewickley', 'Cranberry Twp', 'Moon Twp', 'Wexford', 'Canonsburg'].map(area => (
          <span class="px-4 py-2 bg-background border border-border rounded-full text-sm font-medium text-foreground/80">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12">
      <div class="bg-foreground rounded-2xl p-10 md:p-16 text-center">
        <h2 class="text-background mb-4">Ready to Start Your Fence Project?</h2>
        <p class="text-background/70 max-w-xl mx-auto mb-8">
          Contact us today for a free estimate. We will come to your property, discuss your needs, and provide a competitive quote.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-primary text-primary-foreground font-semibold rounded-full text-sm">
            Request a Free Estimate
          </a>
          <a href="tel:412-766-1464" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-background/30 text-background font-semibold rounded-full text-sm">
            Call 412-766-1464
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
